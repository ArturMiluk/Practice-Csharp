<Window x:Class="StudentDiary.Views.AddEditGradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оценка"
        Height="420"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <TextBlock Text="Студент:" FontWeight="Bold"/>
        <TextBlock x:Name="StudentNameTextBlock" Margin="0,5,0,15"/>

        <TextBlock Text="Предмет:"/>
        <TextBox x:Name="SubjectTextBox" Margin="0,5,0,10"/>

        <TextBlock Text="Оценка (1-10):"/>
        <TextBox x:Name="GradeTextBox" Margin="0,5,0,10"/>

        <TextBlock Text="Дата:"/>
        <DatePicker x:Name="DatePickerControl" Margin="0,5,0,10"/>

        <TextBlock Text="Комментарий:"/>
        <TextBox x:Name="CommentTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="5" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>