<Window x:Class="StudentDiary.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный дневник"
        Height="600"
        Width="1000">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddGradeCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditGradeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteGradeCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding LoadCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding LoadDiaryCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button" x:Key="AddButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightGreen" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="EditButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightYellow" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DeleteButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightCoral" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Загрузить (сервер)" Command="{Binding LoadCommand}" InputGestureText="Ctrl+L"/>
                <MenuItem Header="Загрузить из файла" Command="{Binding LoadDiaryCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Сохранить" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Студенты"/>
            <MenuItem Header="Оценки">
                <MenuItem Header="Добавить" Command="{Binding AddGradeCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditGradeCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteGradeCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="Настройки"/>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="Загрузить" Command="{Binding LoadCommand}" ToolTip="Ctrl+L"/>
            <Separator/>
            <Button Content="Добавить оценку" Command="{Binding AddGradeCommand}" Style="{StaticResource AddButtonStyle}" ToolTip="Ctrl+N"/>
            <Button Content="Редактировать" Command="{Binding EditGradeCommand}" Style="{StaticResource EditButtonStyle}" ToolTip="Ctrl+E"/>
            <Button Content="Удалить" Command="{Binding DeleteGradeCommand}" Style="{StaticResource DeleteButtonStyle}" ToolTip="Del"/>
            <Separator/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" ToolTip="Ctrl+S"/>
            <Button Content="Загрузить из файла" Command="{Binding LoadDiaryCommand}" ToolTip="Ctrl+O"/>
        </ToolBar>

        <TabControl Grid.Row="2" Margin="0,10,0,10">
            <TabItem Header="Оценки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Загрузка..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                               Foreground="Red" FontWeight="Bold" Margin="5"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" ItemsSource="{Binding Students}"
                                 SelectedItem="{Binding SelectedStudent}"
                                 Margin="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="5" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Grades.Count, StringFormat=Оценок: {0}}" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Grid.Column="1" ItemsSource="{Binding SelectedStudent.Grades}"
                                 SelectedItem="{Binding SelectedGrade}"
                                 Margin="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Subject}" Width="150"/>
                                            <TextBlock Text="{Binding Grade}" Width="50" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Расписание">
                <Grid Margin="10">
                    <TextBlock Text="Здесь будет расписание занятий" 
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Чат" FontWeight="Bold" Margin="5" Background="LightGray"/>

                <ListBox x:Name="ChatListBox" Grid.Row="1" Margin="5"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ChatInputTextBox" Margin="5"/>
                    <Button Grid.Column="1" Content="Отправить" Margin="5" Click="SendChatMessage_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>