@model List<BookLibrary.Models.Book>

@{
    ViewData["Title"] = "Библиотека книг";
}

<h2>Библиотека книг</h2>

<p>
    <a href="@Url.Action("Add")" class="btn btn-primary">Добавить новую книгу</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Год</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Year</td>
                <td>
                    <a href="@Url.Action("Details", new { id = book.Id })" class="btn btn-sm btn-info">Подробнее</a>
                </td>
            </tr>
        }
    </tbody>
</table>