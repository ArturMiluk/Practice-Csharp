@model BookLibrary.Models.Book

@{
    ViewData["Title"] = "Удаление книги";
}

<h2>Удаление книги</h2>

<div class="alert alert-danger">
    <strong>Внимание!</strong> Вы уверены, что хотите удалить эту книгу?
</div>

<div class="card" style="width: 500px;">
    <div class="card-body">
        <p><strong>Название:</strong> @Model.Title</p>
        <p><strong>Автор:</strong> @Model.Author</p>
        <p><strong>ISBN:</strong> @Model.ISBN</p>
        <p><strong>Жанр:</strong> @Model.Genre</p>
        <p><strong>Год:</strong> @Model.Year</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Да, удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Нет, вернуться</a>
</form>