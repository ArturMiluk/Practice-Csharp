@model List<BookLibrary.Models.Book>

@{
    ViewData["Title"] = "Библиотека книг";
}

<h2>Библиотека книг</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a href="@Url.Action("Add")" class="btn btn-primary">Добавить новую книгу</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>ISBN</th>
            <th>Жанр</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.ISBN</td>
                <td>@book.Genre</td>
                <td>
                    <a href="@Url.Action("Details", new { id = book.Id })" class="btn btn-sm btn-info">Подробнее</a>
                </td>
            </tr>
        }
    </tbody>
</table>