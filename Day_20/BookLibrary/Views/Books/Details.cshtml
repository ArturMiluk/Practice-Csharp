@model BookLibrary.Models.Book

@{
    ViewData["Title"] = "Детали книги";
}

<h2>@Model.Title</h2>

<div class="card" style="width: 500px;">
    <div class="card-body">
        <p><strong>Автор:</strong> @Model.Author</p>
        <p><strong>ISBN:</strong> @Model.ISBN</p>
        <p><strong>Жанр:</strong> @Model.Genre</p>
        <p><strong>Год издания:</strong> @Model.Year</p>
        <p><strong>Дата добавления:</strong> @Model.DateAdded.ToShortDateString()</p>
    </div>
</div>

<p class="mt-3">
    <a href="@Url.Action("Index")" class="btn btn-secondary">Назад к списку</a>
</p>