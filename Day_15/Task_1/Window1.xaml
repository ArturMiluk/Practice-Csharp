<Window x:Class="StudentDiary.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный дневник"
        Height="500"
        Width="900">

    <Window.InputBindings>
        <KeyBinding Key="L" Modifiers="Control"
                    Command="{Binding LoadCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button" x:Key="FancyButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightGreen"
                                Padding="5"
                                CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Студенты"/>
            <MenuItem Header="Оценки"/>
        </Menu>

        <ToolBar Grid.Row="1">

            <Button Content="Загрузить студентов"
                    Margin="5"
                    Command="{Binding LoadCommand}"/>

            <Separator/>

            <Button Content="Обновить"
                    Style="{StaticResource FancyButton}"
                    Margin="5"
                    Command="{Binding LoadCommand}"/>

        </ToolBar>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Загрузка..."
                       Foreground="Red"
                       FontWeight="Bold"
                       Margin="5"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Students}"
                     Margin="5">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="5"
                                Margin="5">

                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           FontSize="14"/>

                                <ItemsControl ItemsSource="{Binding Grades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="2">
                                                <TextBlock Text="{Binding Subject}" Width="120"/>
                                                <TextBlock Text="{Binding Grade}" Width="40"/>
                                                <TextBlock Text="{Binding Date}" Width="120"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

        </Grid>
    </Grid>
</Window>