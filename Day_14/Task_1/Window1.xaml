<Window x:Class="StudentDiary.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный дневник"
        Height="500"
        Width="900">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control"
                    Command="{Binding AddGradeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control"
                    Command="{Binding EditGradeCommand}"/>
        <KeyBinding Key="Delete"
                    Command="{Binding DeleteGradeCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button" x:Key="FancyButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightGreen"
                                Padding="5"
                                CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Расписание"/>
            <MenuItem Header="Оценки"/>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="Добавить"
                    Margin="5"
                    Command="{Binding AddGradeCommand}"/>

            <Button Content="Редактировать"
                    Margin="5"
                    Command="{Binding EditGradeCommand}"/>

            <Button Content="Удалить"
                    Margin="5"
                    Command="{Binding DeleteGradeCommand}"/>

            <Separator/>

            <Button Content="Обновить оценки"
                    Style="{StaticResource FancyButton}"
                    Margin="5"
                    Command="{Binding RefreshCommand}"/>
        </ToolBar>

        <TabControl Grid.Row="2">
            <TabItem Header="Расписание">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Фильтр по дате:" VerticalAlignment="Center"/>
                        <DatePicker x:Name="dateFilterPicker" Margin="10,0"/>
                        <Button Content="Применить"
                                Click="OnFilterClick"/>
                    </StackPanel>

                    <DataGrid x:Name="scheduleGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              ItemsSource="{Binding Records}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Предмет"
                                Binding="{Binding Subject, Mode=TwoWay}"/>

                            <DataGridTextColumn Header="Дата"
                                Binding="{Binding Date, Mode=TwoWay}"/>

                            <DataGridTextColumn Header="Оценка"
                                Binding="{Binding Grade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ListView Grid.Row="2"
                              Margin="0,10,0,0"
                              Height="100"
                              ItemsSource="{Binding Records}">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Subject}" Width="120"/>
                                    <TextBlock Text="{Binding Date}" Width="150"/>
                                    <TextBlock Text="{Binding Grade}" Width="50"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                    <TextBlock Grid.Row="3"
                               HorizontalAlignment="Left"
                               Margin="0,10,0,0"
                               FontWeight="Bold"
                               Text="{Binding AverageGrade, StringFormat=Средний балл: {0:F2}}"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>