<Window x:Class="StudentDiary.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный дневник"
        Height="600"
        Width="1000"
        x:Name="MainWindow">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddGradeCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditGradeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteGradeCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding LoadCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding LoadDiaryCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Storyboard x:Key="HighlightGradeAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="0.5" To="1" Duration="0:0:0.3"
                AutoReverse="True"/>
        </Storyboard>

        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>

        <Storyboard x:Key="FadeOutAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <Style TargetType="Button" x:Key="AddButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightGreen" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" " FontSize="14"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="EditButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightYellow" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" " FontSize="14"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DeleteButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="LightCoral" Padding="5" CornerRadius="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" " FontSize="14"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10" x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Загрузить (сервер)" Command="{Binding LoadCommand}" InputGestureText="Ctrl+L"/>
                <MenuItem Header="Загрузить из файла" Command="{Binding LoadDiaryCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Сохранить" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Студенты"/>
            <MenuItem Header="Оценки">
                <MenuItem Header="Добавить" Command="{Binding AddGradeCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditGradeCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteGradeCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="Настройки"/>
        </Menu>

        <ToolBar Grid.Row="1">
            <Button Content="Загрузить" Command="{Binding LoadCommand}" ToolTip="Ctrl+L"/>
            <Separator/>
            <Button Content="Добавить оценку" Command="{Binding AddGradeCommand}" Style="{StaticResource AddButtonStyle}" ToolTip="Ctrl+N"/>
            <Button Content="Редактировать" Command="{Binding EditGradeCommand}" Style="{StaticResource EditButtonStyle}" ToolTip="Ctrl+E"/>
            <Button Content="Удалить" Command="{Binding DeleteGradeCommand}" Style="{StaticResource DeleteButtonStyle}" ToolTip="Del"/>
            <Separator/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" ToolTip="Ctrl+S"/>
            <Button Content="Загрузить из файла" Command="{Binding LoadDiaryCommand}" ToolTip="Ctrl+O"/>
        </ToolBar>

        <TabControl Grid.Row="2" Margin="0,10,0,10">
            <TabItem Header="Оценки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Загрузка..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                               Foreground="Red" FontWeight="Bold" Margin="5"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" ItemsSource="{Binding Students}"
                                 SelectedItem="{Binding SelectedStudent}"
                                 Margin="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="5" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Grades.Count, StringFormat=Оценок: {0}}" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox x:Name="GradesListBox"
                                 Grid.Column="1" 
                                 ItemsSource="{Binding SelectedStudent.Grades}"
                                 SelectedItem="{Binding SelectedGrade}"
                                 Margin="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="GradeBorder" 
                                            BorderBrush="Gray" 
                                            BorderThickness="1" 
                                            CornerRadius="5"
                                            Padding="5"
                                            Margin="5"
                                            Background="White">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="GradeSubject" Text="{Binding Subject}" Width="150" FontSize="13"/>
                                            <TextBlock x:Name="GradeValue" Text="{Binding Grade}" Width="50" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock x:Name="GradeDate" Text="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" Width="100" FontSize="12"/>
                                            <Button Content="Детали" Width="50" Cursor="Hand" 
                                                    Click="ShowGradeDetails_Click"
                                                    Tag="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"/>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <EventTrigger RoutedEvent="Border.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource HighlightGradeAnimation}"/>
                                        </EventTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Расписание">
                <Grid Margin="10">
                    <TextBlock Text="Здесь будет расписание занятий" 
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Чат" FontWeight="Bold" Margin="5" Background="LightGray"/>

                <ListBox x:Name="ChatListBox" Grid.Row="1" Margin="5"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ChatInputTextBox" Margin="5"/>
                    <Button Grid.Column="1" Content="Отправить" Margin="5" Click="SendChatMessage_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Popup x:Name="GradeDetailsPopup" 
               Grid.Row="4"
               PlacementTarget="{Binding ElementName=MainGrid}"
               Placement="Center"
               AllowsTransparency="True"
               StaysOpen="False">
            <Border x:Name="PopupBorder"
                    Background="White"
                    BorderBrush="DarkBlue"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="15"
                    Width="300"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                </Border.RenderTransform>
                <Border.Resources>
                    <Storyboard x:Key="ShowPopupAnim" Completed="ShowPopupAnim_Completed">
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                         From="0.5" To="1" Duration="0:0:0.2"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                         From="0.5" To="1" Duration="0:0:0.2"/>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                         From="0" To="1" Duration="0:0:0.2"/>
                    </Storyboard>
                    <Storyboard x:Key="HidePopupAnim">
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                         From="1" To="0.5" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                         From="1" To="0.5" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                         From="1" To="0" Duration="0:0:0.15"/>
                    </Storyboard>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Детали оценки" 
                               FontWeight="Bold" 
                               FontSize="16"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Предмет:" FontWeight="Bold" Grid.Column="0" Grid.Row="0"/>
                        <TextBlock x:Name="DetailSubject" Grid.Column="1" Grid.Row="0"/>

                        <TextBlock Text="Оценка:" FontWeight="Bold" Grid.Column="0" Grid.Row="1"/>
                        <TextBlock x:Name="DetailGrade" Grid.Column="1" Grid.Row="1" FontWeight="Bold"/>

                        <TextBlock Text="Дата:" FontWeight="Bold" Grid.Column="0" Grid.Row="2"/>
                        <TextBlock x:Name="DetailDate" Grid.Column="1" Grid.Row="2"/>

                        <TextBlock Text="Комментарий:" FontWeight="Bold" Grid.Column="0" Grid.Row="3" Margin="0,10,0,0"/>
                        <TextBox x:Name="DetailComment" Grid.Column="1" Grid.Row="3" 
                                 Height="60" TextWrapping="Wrap" 
                                 AcceptsReturn="True" Margin="0,10,0,0"/>
                    </Grid>
                    <Button Content="Закрыть" 
                            Margin="0,15,0,0"
                            HorizontalAlignment="Center"
                            Width="100"
                            Click="ClosePopup_Click"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>